pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            } // Closes Build agent
            steps {
                sh '''
                npm ci
                npm run build
                '''
            }
        } // Closes Build stage

        stage('Test') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            } // Closes Test agent
            steps {
                sh 'npm test'
            }
        } // Closes Test stage
    } // Closes all stages
} // Closes the pipeline